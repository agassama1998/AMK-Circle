# Normalize line endings to LF in the repo; checkout as-is on all platforms
* text=auto eol=lf

# Force LF for shell scripts and config files
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf

# Binaries — no line-ending conversion
*.png binary
*.jpg binary
*.ico binary
*.node binary
