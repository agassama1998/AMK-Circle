# ─────────────────────────────────────────────────────────────────────────────
# AMK Circle — Environment Variables Example
# Copy this file to .env and fill in the values.
# For Electron desktop builds, most of these are set inside electron/handlers/auth.js
# and electron/database/db.js directly.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server (Docker / cloud mode only) ────────────────────────────────────────
NODE_ENV=production
PORT=3000

# CRITICAL: Change this secret before any production deployment!
JWT_SECRET=amkcircle-jwt-secret-change-in-production-min-32-chars

# Database path inside the Docker volume
DB_PATH=/data/amkcircle.sqlite

# ── Application defaults ──────────────────────────────────────────────────────
APP_NAME="AMK Circle"
APP_URL=https://amkcircle.com

# ── Electron specific (set in electron/handlers/auth.js) ─────────────────────
# ELECTRON_JWT_SECRET=your-local-desktop-secret

# ── Optional: SMTP for email notifications (future feature) ──────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# SMTP_FROM="AMK Circle <noreply@amkcircle.com>"
